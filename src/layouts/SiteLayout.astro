---
// Single unified English-language layout for the whole site.
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}
const { title, description, ogImage = "/og/default.png" } = Astro.props;
const siteName = "PoE2 Hub";
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | {siteName}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-BE38KVGCF3"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-BE38KVGCF3');
    </script>

    <!-- Google AdSense -->
    <meta name="google-adsense-account" content="ca-pub-8250482430797594" />
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8250482430797594" crossorigin="anonymous"></script>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="brand">PoE2 Hub</a>
        <nav>
          <a href="/getting-started/">Guides</a>
          <a href="/builds/tier-list/">Builds</a>
          <a href="/bosses/">Bosses</a>
          <a href="/mechanics/">Mechanics</a>
          <a href="/unique-items/">Items</a>
          <a href="/news/">News</a>
          <a href="/chromatic-calculator/">Tools</a>
          <a href="/faq/">FAQ</a>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p>Content is updated to track current PoE2 patches. Check the version note on each page.</p>
        <nav class="footer-nav">
          <a href="/about/">About</a>
          <a href="/contact/">Contact</a>
          <a href="/privacy-policy/">Privacy Policy</a>
          <a href="/terms-of-service/">Terms of Service</a>
        </nav>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  .site-header {
    border-bottom: 1px solid var(--border-hairline);
    background: var(--bg-elevated);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-2) var(--space-2);
    flex-wrap: wrap;
    gap: var(--space-1);
  }
  .brand {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--accent-gold);
    letter-spacing: 0.05em;
  }
  .brand:hover { text-decoration: none; }
  nav { display: flex; gap: var(--space-2); flex-wrap: wrap; }
  nav a { color: var(--text-dim); font-size: 0.95rem; }
  nav a:hover { color: var(--accent-verdigris-bright); }

  main { padding-top: var(--space-4); padding-bottom: var(--space-5); min-height: 60vh; }

  .site-footer {
    border-top: 1px solid var(--border-hairline);
    color: var(--text-faint);
    font-size: 0.85rem;
    padding: var(--space-3) 0;
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .footer-nav { display: flex; gap: var(--space-2); }
  .footer-nav a { color: var(--text-faint); }
  .footer-nav a:hover { color: var(--accent-verdigris-bright); }
</style>
