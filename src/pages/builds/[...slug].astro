---
import { getCollection, getEntry } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";
import ItemTooltipCard from "../../components/ItemTooltipCard.astro";
import FaqAccordion from "../../components/FaqAccordion.astro";
import RelatedGrid from "../../components/RelatedGrid.astro";

export async function getStaticPaths() {
  const entries = await getCollection("builds");
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const b = entry.data;

// Fetch linked Boss/Mechanics entries to build the "Related Guides" cards
const relatedBosses = await Promise.all(
  (b.relatedBosses ?? []).map((ref: any) => getEntry(ref))
);
const relatedMechanics = await Promise.all(
  (b.relatedMechanics ?? []).map((ref: any) => getEntry(ref))
);
const relatedItems = [
  ...relatedBosses.filter(Boolean).map((r: any) => ({
    kicker: "BOSS GUIDE", title: r.data.title, href: `/bosses/${r.slug}/`,
  })),
  ...relatedMechanics.filter(Boolean).map((r: any) => ({
    kicker: "MECHANICS", title: r.data.title, href: `/mechanics/${r.slug}/`,
  })),
];

const tierColor: Record<string, string> = {
  S: "var(--accent-rust-bright)",
  A: "var(--rarity-rare)",
  B: "var(--rarity-magic)",
  C: "var(--text-faint)",
};

// OG PNG文件名是脚本按 slug 里的 "/" 换成 "-" 生成的（见 scripts/generate-og.mjs），
// 这里必须用同样的规则拼路径，否则OG图对不上，页面分享出去会用默认图。
const ogImage = `/og/builds/${entry.slug.replaceAll("/", "-")}.png`;
---
<SiteLayout
  title={b.title}
  description={b.summary}
  ogImage={ogImage}
>
  <p class="version-flag">Last verified against: {b.patchVersion} · updated {b.updatedAt.toISOString().slice(0,10)}</p>

  <h1>{b.title}</h1>

  <!-- TL;DR box: fixed first-screen element on every Build page -->
  <div class="tldr-box">
    <h3>Overview</h3>
    <p>{b.summary}</p>
    <div class="tldr-grid">
      <div class="tldr-item">
        <div class="label">Tier Rating</div>
        <div class="value" style={`color:${tierColor[b.tier]}`}>{b.tier} Tier</div>
      </div>
      <div class="tldr-item">
        <div class="label">Best For</div>
        <div class="value">{b.playstyle}</div>
      </div>
      <div class="tldr-item">
        <div class="label">Est. Cost</div>
        <div class="value">{b.estCost}</div>
      </div>
      <div class="tldr-item">
        <div class="label">Core Mechanic</div>
        <div class="value">{b.coreSkill}</div>
      </div>
    </div>
  </div>

  <h2>Pros & Cons</h2>
  <div class="pros-cons">
    <div>
      <h3>Pros</h3>
      <ul>{b.pros.map((p: string) => <li>{p}</li>)}</ul>
    </div>
    <div>
      <h3>Cons</h3>
      <ul>{b.cons.map((c: string) => <li>{c}</li>)}</ul>
    </div>
  </div>

  {b.ascendancyNodes && b.ascendancyNodes.length > 0 && (
    <>
      <h2>Ascendancy Nodes</h2>
      {!b.nodesVerified && (
        <p class="verify-note">
          ⚠️ Node names below reflect the general mechanic direction confirmed across community
          guides, but haven't been individually cross-checked node-by-node against the current
          in-game tree — verify exact names before publishing as a definitive reference.
        </p>
      )}
      <ol class="node-list">
        {b.ascendancyNodes.sort((a: any, b2: any) => a.order - b2.order).map((n: any) => (
          <li><strong>{n.name}</strong> — {n.effect}</li>
        ))}
      </ol>
    </>
  )}

  <h2>Full Guide</h2>
  <div class="prose"><Content /></div>

  {b.skillGems && (
    <>
      <h2>Skill Gem Setup</h2>
      <div class="gem-setup-grid">
        {b.skillGems.mainSkill && (
          <div class="gem-setup-card">
            <div class="gem-setup-label">Main Skill</div>
            <div class="gem-setup-name">{b.skillGems.mainSkill.gem}</div>
            <div class="gem-setup-supports">{b.skillGems.mainSkill.supports.join(" · ")}</div>
          </div>
        )}
        {b.skillGems.secondarySkill && (
          <div class="gem-setup-card">
            <div class="gem-setup-label">Secondary Skill</div>
            <div class="gem-setup-name">{b.skillGems.secondarySkill.gem}</div>
            <div class="gem-setup-supports">{b.skillGems.secondarySkill.supports.join(" · ")}</div>
          </div>
        )}
        {b.skillGems.spiritSkills.map((s: any) => (
          <div class="gem-setup-card">
            <div class="gem-setup-label">Spirit Skill</div>
            <div class="gem-setup-name">{s.gem}</div>
            <div class="gem-setup-supports">{s.supports.join(" · ")}</div>
          </div>
        ))}
        {b.skillGems.utilitySkills.map((s: any) => (
          <div class="gem-setup-card">
            <div class="gem-setup-label">Utility</div>
            <div class="gem-setup-name">{s.gem}</div>
            <div class="gem-setup-supports">{s.supports.join(" · ")}</div>
          </div>
        ))}
      </div>
    </>
  )}

  <h2>Gear Priority</h2>
  {b.gearPriority.map((g: any) => (
    <ItemTooltipCard gearSlot={g.slot} item={g.item} note={g.note} priority={g.priority} />
  ))}

  {b.passiveTreePriority && (
    <>
      <h2>Passive Tree Priority</h2>
      <ul class="tree-priority-list">
        <li><strong>Early game:</strong> {b.passiveTreePriority.earlyGame}</li>
        <li><strong>Mid game:</strong> {b.passiveTreePriority.midGame}</li>
        <li><strong>End game:</strong> {b.passiveTreePriority.endGame}</li>
      </ul>
    </>
  )}

  {b.levelingGuide && (
    <>
      <h2>Leveling Guide</h2>
      <ul class="tree-priority-list">
        <li><strong>Act 1–3:</strong> {b.levelingGuide.act1to3}</li>
        <li><strong>Act 4–6:</strong> {b.levelingGuide.act4to6}</li>
        <li><strong>Mapping:</strong> {b.levelingGuide.mapping}</li>
      </ul>
    </>
  )}

  <FaqAccordion faqs={b.faqs} />

  <RelatedGrid items={relatedItems} />

  {b.dataSources && b.dataSources.length > 0 && (
    <p class="sources-note">Sources cross-checked: {b.dataSources.join(" · ")}</p>
  )}
</SiteLayout>

<style>
  .pros-cons {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }
  .pros-cons ul { padding-left: 1.2em; color: var(--text-dim); }
  .prose { color: var(--text-dim); line-height: 1.75; }
  @media (max-width: 600px) {
    .pros-cons { grid-template-columns: 1fr; }
  }
  .verify-note {
    font-size: 0.85rem;
    color: var(--accent-rust-bright);
    border-left: 2px solid var(--accent-rust);
    padding-left: 0.8em;
  }
  .node-list { color: var(--text-dim); padding-left: 1.2em; }
  .node-list li { margin-bottom: 0.4em; }
  .node-list strong { color: var(--accent-gold); }

  .gem-setup-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }
  .gem-setup-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border-hairline);
    border-radius: var(--radius-sm);
    padding: var(--space-2);
  }
  .gem-setup-label { font-size: 0.72rem; text-transform: uppercase; color: var(--text-faint); font-family: var(--font-mono); }
  .gem-setup-name { font-family: var(--font-display); color: var(--text); margin: 0.2rem 0; }
  .gem-setup-supports { font-size: 0.85rem; color: var(--text-dim); }

  .tree-priority-list { color: var(--text-dim); padding-left: 1.2em; }
  .tree-priority-list li { margin-bottom: 0.5em; }

  .sources-note { font-size: 0.78rem; color: var(--text-faint); margin-top: var(--space-3); }
</style>
