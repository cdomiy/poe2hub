---
import SiteLayout from "../../layouts/SiteLayout.astro";
import RelatedGrid from "../../components/RelatedGrid.astro";

const categories = [
  {
    label: "Endgame Chase Items",
    note: "The items most builds are ultimately grinding toward — expensive, and often build-defining rather than just stat sticks.",
    items: [
      {
        name: "Mageblood",
        slot: "Belt",
        effect: "Grants 1-3 Charm Slots, which let defensive and offensive effects trigger automatically on specific conditions with no button press required — effectively running several passive triggers at once.",
        note: "No dedicated boss drop. Best farmed by targeting the Ritual Foretold Bounty system, since specific maps carry specific bounty pools.",
      },
      {
        name: "Headhunter",
        slot: "Belt",
        effect: "Steals modifiers from rare monsters you kill for a limited time, letting your character temporarily gain buffs and passives that rares normally get.",
        note: "One of the most iconic items carried over conceptually from the original Path of Exile — beloved for turbocharging rare-pack farming.",
      },
      {
        name: "Temporalis",
        slot: "Body Armour",
        effect: "A top-end piece for cooldown-focused builds and advanced skill rotations built around resetting or manipulating skill timers.",
      },
      {
        name: "The Adorned",
        slot: "Jewel",
        effect: "Massively amplifies the effect of Jewel Socket passive nodes that hold corrupted magic jewels — a scaling tool for characters with many jewel sockets and heavy investment.",
      },
      {
        name: "Voices",
        slot: "Jewel",
        effect: "Adds 2-4 Sinister Jewel Sockets near the passive tree's center — extra room for regular (non-unique) jewels, which are often a very high-value passive investment.",
        note: "Drops from the Simulacrum of Delusion encounter, which requires 300 Simulacrum Splinters to open — a serious investment to even attempt.",
      },
    ],
  },
  {
    label: "Build-Defining Picks",
    note: "Items that don't just add stats — they unlock or fundamentally reshape a specific playstyle.",
    items: [
      {
        name: "Facebreaker",
        slot: "Gloves",
        effect: "Scales unarmed damage directly off Strength, and functions as a one-handed mace with both hands empty — unlocking mace skill gems for a fully unarmed character.",
        note: "A world drop with no level requirement, making it accessible early if you're building around Strength stacking.",
      },
      {
        name: "Liminal Coil",
        slot: "Wand",
        effect: "Removes the normal cap on how many curses you can have active on one target, and adds a damage multiplier per active curse — turning a curse-stacking build's damage into a genuine multiplier stack instead of one or two debuffs.",
        note: "The canonical home for this item is a curse-stacking Witch build.",
        relatedBuild: "witch/lich",
      },
      {
        name: "Svalinn",
        slot: "Shield",
        effect: "A premier block-based defensive shield — its 'damage taken from blocked hits' roll was improved in the 0.5.0 Runic Ward update, making a high block-chance build feel much closer to immune against attacks.",
      },
      {
        name: "Loreweave",
        slot: "Body Armour",
        effect: "A flexible endgame chest piece for builds that want a balance of damage and defense rather than committing hard to one or the other.",
      },
      {
        name: "Prism of Belief",
        slot: "Jewel",
        effect: "Built for builds that concentrate nearly all their damage into a single main skill, amplifying that one skill heavily rather than spreading benefit across multiple abilities.",
      },
    ],
  },
  {
    label: "Budget & Leveling Picks",
    note: "Accessible items that punch well above their acquisition cost — good targets before you can afford the chase items above.",
    items: [
      {
        name: "Cat O' Nine Tails",
        slot: "Belt",
        effect: "Sometimes called the 'budget Mageblood' — grants 1-3 Charm Slots and instantly restores 20% of flask recovery, giving a taste of the automatic-trigger playstyle at a fraction of Mageblood's cost.",
      },
      {
        name: "Cloak of Flame",
        slot: "Body Armour",
        effect: "Converts incoming physical damage to fire through a straightforward defensive philosophy — a simple, low-investment way to mitigate physical hits before your defenses are fully built out.",
        note: "Especially useful in early-to-mid endgame, and a good fit for fire-resistance-focused builds.",
      },
      {
        name: "Astramentis",
        slot: "Amulet",
        effect: "A flat boost to all four core attributes — cheap insurance against attribute-gated gear and skills, and a staple leveling-into-endgame amulet across many build types.",
      },
      {
        name: "Ingenuity",
        slot: "Belt",
        effect: "Scales its bonuses based on the rings you have equipped, rewarding builds that already invest heavily in strong ring slots.",
      },
    ],
  },
  {
    label: "Weapons",
    note: "Unique weapons in PoE2 usually define a specific mechanic rather than just adding bigger numbers — pick based on what your build is already trying to do, not raw stats.",
    items: [
      {
        name: "The Ordained",
        slot: "Spear",
        effect: "The premier endgame physical/lightning hybrid spear of 0.5 — grants Righteous Descent (a striking divine leap skill with strong mobility) and periodically creates a Fragment of Divinity that empowers your next action, on top of very competitive raw physical and lightning damage rolls.",
        note: "Dominates high-tier maps and pinnacle content on lightning-focused melee spear builds.",
      },
      {
        name: "Atziri's Contempt",
        slot: "Spear",
        effect: "Spear skills inflict stacking Bloodstone Lance on hit (up to 30 stacks per target), turning repeated spear hits into a scaling payoff — built specifically for Bloodstone Lance-focused builds rather than general use.",
      },
      {
        name: "Tangletongue",
        slot: "Spear",
        effect: "A standout leveling spear thanks to added crit chance, Intelligence, physical damage, and forking critical hits — more build-defining personality than a typical leveling unique.",
      },
      {
        name: "Skysliver",
        slot: "Spear",
        effect: "A lightning-focused leveling weapon with no physical damage but strong added lightning damage and improved shock chance — a solid pick for fast-attacking shock-focused starts.",
      },
      {
        name: "Goldrim",
        slot: "Helmet",
        effect: "A classic early-game helmet that patches over rough elemental resistances during the campaign — unglamorous, but it solves a real problem at a point when rare gear can't yet.",
      },
      {
        name: "Wanderlust",
        slot: "Boots",
        effect: "Strong leveling boots for movement speed, smoothing out zone clearing well before you have better rare alternatives.",
      },
    ],
  },
  {
    label: "Jewels",
    note: "Jewels socket directly into the passive tree and are one of the most flexible scaling tools in the game, several of these are close to mandatory once you understand what they do.",
    items: [
      {
        name: "Grand Spectrum",
        slot: "Jewel",
        effect: "A set of jewels that scale multiplicatively with copies of themselves (limit 3). The Sapphire variant grants elemental resistance per jewel, commonly stacked as three-of-a-kind to cap resistances and free up suffix space on other gear; other variants trade into maximum Life or Spirit instead.",
        note: "One of the most efficient ways to solve resistance-capping without reworking your passive tree.",
      },
      {
        name: "Time-Lost Jewel",
        slot: "Jewel",
        effect: "Increases the effect of Small Passives within its radius by roughly 15-30%, turning a cluster of otherwise-mediocre small nodes into a genuine power spike. Works on any build with a dense enough small-passive cluster nearby.",
      },
      {
        name: "Against the Darkness",
        slot: "Jewel",
        effect: "Boosts attribute-granting passives within its radius, particularly strong for Intelligence-focused stat-stacking casters. Best placed near clusters with several attribute notables to maximize the radius overlap.",
      },
    ],
  },
  {
    label: "Rings, Amulets, Flasks & Shields",
    note: "The accessory and off-hand slots where a lot of PoE2's most build-defining (and most unusual) mechanics live.",
    items: [
      {
        name: "Ventor's Gamble",
        slot: "Ring",
        effect: "A pure gamble item: rolls a wide range of modifiers including item rarity, elemental resistances, and Spirit, but can roll negative values on almost any stat. A great roll is one of the best Magic Find rings in the game; a bad one is close to worthless.",
        note: "Only obtainable as a random drop or through chance-crafting, it can't be reliably targeted.",
      },
      {
        name: "Kalandra's Touch",
        slot: "Ring",
        effect: "A ring with no modifiers of its own, it simply duplicates the stats of your other equipped ring. Useful once you've already invested heavily in one expensive ring and would rather copy it than buy a second one at full price.",
      },
      {
        name: "Sekhema's Resolve",
        slot: "Ring",
        effect: "Negates the elemental resistance penalty applied after completing the campaign for its specific element (Fire, Cold, or Lightning depending on variant), effectively a large, permanent resistance boost. Also has a jewel socket for further customization.",
      },
      {
        name: "Defiance of Destiny",
        slot: "Amulet",
        effect: "Recovers a percentage of your Life before damage from a Hit is applied, smoothing out burst damage significantly. One of the strongest general-purpose defensive amulets in the game, especially valuable against single hard-hitting attacks rather than sustained pressure.",
        note: "Works best on Life-based builds; less useful if you're running pure Energy Shield.",
      },
      {
        name: "Olroth's Resolve",
        slot: "Flask",
        effect: "Allows Life Flask recovery to overheal past your maximum Life, converting the excess into Guard. A meaningful survivability boost even for builds that haven't otherwise invested in flask effectiveness.",
      },
      {
        name: "Mahuxotl's Machination",
        slot: "Shield",
        effect: "Reworks the standard defense model around Soul Core sockets and non-standard damage distribution rather than plain block or armour. Genuinely difficult to gear around correctly, but capable of surviving hits that would otherwise be fatal once properly tuned.",
      },
    ],
  },
];

const relatedItems = [
  { kicker: "RELATED BUILD", title: "Witch Lich Chaos Curse Build", href: "/builds/witch/lich/" },
  { kicker: "MECHANICS", title: "Runes of Aldur League Mechanic Guide", href: "/mechanics/runes-of-aldur/" },
  { kicker: "MECHANICS", title: "Passive Skill Tree Explained", href: "/mechanics/passive-tree/" },
  { kicker: "REFERENCE", title: "Skill Gems, Support Gems & Spirit Gems", href: "/skill-gems/" },
];
---
<SiteLayout
  title="PoE2 Unique Items Database"
  description="A verified, curated list of Path of Exile 2's most important unique items, endgame chase pieces, build-defining weapons, and budget-friendly picks."
>
  <p class="version-flag">Covers the current 0.5.x unique item pool · Runes of Aldur</p>
  <h1>PoE2 Unique Items</h1>
  <p class="intro">
    This isn't every unique in the game — it's a curated, cross-checked list of the ones that
    actually come up in build planning right now, organized by what problem they solve rather
    than an alphabetical dump.
  </p>

  {categories.map((cat) => (
    <section class="cat-section">
      <h2>{cat.label}</h2>
      <p class="cat-note">{cat.note}</p>
      {cat.items.map((item) => (
        <div class="item-card">
          <div class="item-head">
            <span class="item-name">{item.name}</span>
            <span class="item-slot mono">{item.slot}</span>
          </div>
          <p class="item-effect">{item.effect}</p>
          {item.note && <p class="item-note">{item.note}</p>}
          {item.relatedBuild && (
            <a class="item-link" href={`/builds/${item.relatedBuild}/`}>See the build this powers →</a>
          )}
        </div>
      ))}
    </section>
  ))}

  <RelatedGrid items={relatedItems} />
</SiteLayout>

<style>
  .intro { color: var(--text-dim); }
  .cat-section { margin-bottom: var(--space-4); }
  .cat-note { color: var(--text-faint); font-size: 0.88rem; margin-top: -0.3rem; }
  .item-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border-hairline);
    border-radius: var(--radius-sm);
    padding: var(--space-2);
    margin-bottom: var(--space-2);
  }
  .item-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .item-name { font-family: var(--font-display); font-size: 1.1rem; color: var(--rarity-unique); }
  .item-slot { color: var(--text-faint); font-size: 0.8rem; text-transform: uppercase; }
  .item-effect { color: var(--text-dim); margin: 0.4rem 0; }
  .item-note { color: var(--text-faint); font-size: 0.86rem; }
  .item-link { display: inline-block; font-size: 0.88rem; margin-top: 0.2rem; }
</style>
