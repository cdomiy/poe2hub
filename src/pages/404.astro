---
import SiteLayout from "../layouts/SiteLayout.astro";
---
<SiteLayout
  title="Page Not Found"
  description="This page doesn't exist or has moved."
>
  <div class="notfound">
    <p class="code mono">404</p>
    <h1>This page wandered off the map.</h1>
    <p class="intro">
      The page you're looking for doesn't exist, or the URL changed. Here are a few
      places that are definitely still there:
    </p>
    <div class="links">
      <a class="link-card" href="/">Home</a>
      <a class="link-card" href="/builds/tier-list/">Build Tier List</a>
      <a class="link-card" href="/faq/">FAQ</a>
      <a class="link-card" href="/chromatic-calculator/">Chromatic Calculator</a>
      <a class="link-card" href="/loot-filter-generator/">Loot Filter Generator</a>
    </div>
  </div>
</SiteLayout>

<style>
  .notfound { text-align: center; padding: var(--space-4) 0; }
  .code {
    font-size: 5rem;
    color: var(--accent-rust);
    margin: 0;
    line-height: 1;
  }
  .intro { color: var(--text-dim); max-width: 480px; margin: var(--space-2) auto; }
  .links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.7rem;
    margin-top: var(--space-3);
  }
  .link-card {
    border: 1px solid var(--border-hairline);
    border-radius: var(--radius-sm);
    padding: 0.6em 1.1em;
    color: var(--text-dim);
    font-size: 0.9rem;
  }
  .link-card:hover { border-color: var(--accent-verdigris); color: var(--accent-verdigris-bright); text-decoration: none; }
</style>
