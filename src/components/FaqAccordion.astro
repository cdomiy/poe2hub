---
interface Props {
  faqs: { q: string; a: string }[];
  heading?: string;
  id?: string;
}
const { faqs, heading = "Frequently Asked Questions", id } = Astro.props as Props;

// Generates FAQPage structured data so Google can show a rich-result snippet
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---
{faqs.length > 0 && (
  <section class="faq-section" id={id}>
    <h2>{heading}</h2>
    {faqs.map((f) => (
      <details class="faq-item">
        <summary>{f.q}</summary>
        <p>{f.a}</p>
      </details>
    ))}
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </section>
)}
