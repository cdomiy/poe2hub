---
interface Item {
  kicker: string;   // e.g. "BUILD" / "BOSS" / "MECHANICS"
  title: string;
  href: string;
}
interface Props { items: Item[]; heading?: string }
const { items, heading = "Related Guides" } = Astro.props as Props;
---
{items.length > 0 && (
  <section>
    <h2>{heading}</h2>
    <div class="related-grid">
      {items.map((i) => (
        <a class="related-card" href={i.href}>
          <div class="kicker">{i.kicker}</div>
          <div>{i.title}</div>
        </a>
      ))}
    </div>
  </section>
)}
